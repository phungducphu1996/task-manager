# Local SQLite (dev quick start):
# DATABASE_URL=sqlite:///./social_content.db
#
# Supabase Postgres (recommended for shared data):
# DATABASE_URL=postgresql+psycopg://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres?sslmode=require
# DB_SCHEMA=social

DATABASE_URL=sqlite:///./social_content.db
DB_SCHEMA=
LOCAL_TIMEZONE_OFFSET_HOURS=7
BOT_OWNER_FALLBACK=content-owner

ETSY_API_BASE_URL=http://127.0.0.1:9000/api/v1
ETSY_JWT_SECRET=replace_with_etsy_jwt_secret
ETSY_JWT_ALGORITHM=HS256
AUTH_REQUIRED=true

ZALO_WORKER_URL=
ZALO_SHARED_SECRET=
